# Copy to .env (gitignored). Production values live in RocketRide Cloud
# env config and Butterbase function config — never in git.

# Butterbase
BUTTERBASE_APP_ID=
BUTTERBASE_API_URL=
BUTTERBASE_API_KEY=

# Neo4j Aura
NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Nebius (deep-review judge; OpenAI-compatible)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct

# RocketRide Cloud (extension/CLI auth)
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_AUTH=

# Daytona (bonus)
DAYTONA_API_KEY=

# Pipeline -> Butterbase callback
CALLBACK_URL=
CALLBACK_KEY=
